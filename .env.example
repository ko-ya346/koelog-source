# App runtime database URL.
# Pull the real Development value with:
# vercel env pull .env.local --environment=development
DATABASE_URL=

# Optional migration/direct URL.
# Prefer the Neon non-pooling URL for Drizzle migrations when it is available.
DATABASE_MIGRATION_URL=
DATABASE_URL_UNPOOLED=
POSTGRES_URL_NON_POOLING=

# Legacy/generated aliases from Vercel integrations.
# Keep these blank in source control.
POSTGRES_URL=
